<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="root-pane" prefWidth="800.0" prefHeight="560.0" 
            minWidth="800.0" minHeight="560.0" maxWidth="800.0" maxHeight="560.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.peerlink.ui.MainController">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets left="16" right="16" />
            </padding>
            <Label text="PL" prefWidth="24" prefHeight="24" styleClass="top-bar-logo" />
            <Label text="PeerLink" styleClass="top-bar-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="deviceIpLabel" text="IP: 192.168.1.100" styleClass="top-bar-ip" />
            <Circle fx:id="connectionStatusDot" radius="4" fill="#4a9e6b" />
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar">
            <padding>
                <Insets top="16" bottom="16" />
            </padding>
            <VBox spacing="4" VBox.vgrow="ALWAYS">
                <!-- Navigation Items -->
                <HBox fx:id="navHome" styleClass="nav-item, nav-item-active" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onNavHome">
                    <padding><Insets left="16" right="16" /></padding>
                    <Label text="◈" styleClass="nav-item-icon" />
                    <Label text="Home" styleClass="nav-item-label" />
                </HBox>
                <HBox fx:id="navSend" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onNavSend">
                    <padding><Insets left="16" right="16" /></padding>
                    <Label text="↑" styleClass="nav-item-icon" />
                    <Label text="Send" styleClass="nav-item-label" />
                </HBox>
                <HBox fx:id="navReceive" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onNavReceive">
                    <padding><Insets left="16" right="16" /></padding>
                    <Label text="↓" styleClass="nav-item-icon" />
                    <Label text="Receive" styleClass="nav-item-label" />
                </HBox>
                <HBox fx:id="navDevices" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onNavDevices">
                    <padding><Insets left="16" right="16" /></padding>
                    <Label text="◉" styleClass="nav-item-icon" />
                    <Label text="Devices" styleClass="nav-item-label" />
                </HBox>
            </VBox>
            
            <!-- Bottom Navigation Item -->
            <HBox fx:id="navSettings" styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onNavSettings">
                <padding><Insets left="16" right="16" /></padding>
                <Label text="⚙" styleClass="nav-item-icon" />
                <Label text="Settings" styleClass="nav-item-label" />
            </HBox>
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <StackPane styleClass="content-area">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24" />
            </padding>
            
            <!-- SCREEN 1: HOME DASHBOARD -->
            <VBox fx:id="homeScreen" spacing="24" alignment="CENTER" visible="true" managed="true">
                <!-- Device Identity Card -->
                <VBox styleClass="card" spacing="16" alignment="CENTER" prefWidth="360" maxWidth="360">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24" />
                    </padding>
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="THIS DEVICE" styleClass="section-label" />
                        <Label fx:id="homeDeviceName" text="LocalHost" styleClass="screen-title" />
                    </VBox>
                    <HBox spacing="10" alignment="CENTER">
                        <Label fx:id="homeDeviceIp" text="192.168.1.100" styleClass="code-text" />
                        <Label text="PORT 4220" styleClass="badge, badge-send" fx:id="homeDevicePort" />
                    </HBox>
                    <Separator styleClass="card-divider" />
                    <HBox alignment="CENTER" spacing="8">
                        <Circle fx:id="homeStatusDot" radius="4" fill="#4a9e6b" />
                        <Label text="Ready to transfer" styleClass="status-text" fx:id="homeStatusText" />
                    </HBox>
                </VBox>
                
                <!-- Quick Action Buttons -->
                <HBox spacing="16" alignment="CENTER">
                    <Button text="↑ Send File" prefWidth="160" prefHeight="48" styleClass="btn, btn-primary" onAction="#onNavSend" />
                    <Button text="↓ Receive File" prefWidth="160" prefHeight="48" styleClass="btn, btn-secondary" onAction="#onNavReceive" />
                </HBox>
            </VBox>
            
            <!-- SCREEN 2: SEND SCREEN -->
            <VBox fx:id="sendScreen" spacing="16" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Send File" styleClass="screen-title" />
                </HBox>
                
                <StackPane fx:id="dropZone" styleClass="drop-zone" prefHeight="160" VBox.vgrow="ALWAYS"
                           onDragOver="#onDragOver" onDragDropped="#onDragDropped">
                    <VBox fx:id="dropZoneDefault" alignment="CENTER" spacing="8">
                        <Label text="↑" styleClass="drop-zone-icon" />
                        <Label fx:id="dropZoneLabel" text="Drop file here" styleClass="drop-zone-label" />
                        <Label text="or click to browse" styleClass="drop-zone-sublabel" />
                    </VBox>
                    <VBox fx:id="dropZoneFileInfo" alignment="CENTER" spacing="4" visible="false" managed="false">
                        <Label fx:id="dropZoneFileName" text="" styleClass="drop-zone-filename" />
                        <Label fx:id="dropZoneFileSize" text="" styleClass="drop-zone-filesize" />
                    </VBox>
                    <Button fx:id="removeFileBtn" text="×" styleClass="remove-file-btn" visible="false" managed="false" StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin>
                            <Insets top="8" right="12" />
                        </StackPane.margin>
                    </Button>
                </StackPane>
                
                <Button fx:id="selectFileBtn" text="Browse Files" styleClass="btn, btn-secondary" maxWidth="Infinity" prefHeight="40" onAction="#onSelectFile" />
                
                <!-- Invite Code Section -->
                <VBox fx:id="inviteCodeSection" spacing="6" visible="false" managed="false">
                    <Label text="YOUR INVITE CODE" styleClass="section-label" />
                    <HBox styleClass="code-container" alignment="CENTER_LEFT" spacing="8">
                        <padding>
                            <Insets top="10" right="14" bottom="10" left="14" />
                        </padding>
                        <Label fx:id="inviteCodeLabel" text="" styleClass="code-text" HBox.hgrow="ALWAYS" maxWidth="450" />
                        <Button fx:id="copyCodeBtn" text="⎘" styleClass="btn-icon" onAction="#onCopyCode" />
                    </HBox>
                </VBox>
                
                <Button fx:id="sendBtn" text="→ Start Sending" styleClass="btn, btn-primary" maxWidth="Infinity" prefHeight="44" onAction="#onSend" />
                
                <!-- Progress Section (visible during transfer) -->
                <VBox fx:id="sendProgressSection" spacing="12" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="sendProgressFileName" text="" styleClass="transfer-filename" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="sendProgressFileSize" text="" styleClass="transfer-filesize" />
                    </HBox>
                    <StackPane styleClass="progress-track" prefHeight="6">
                        <ProgressBar fx:id="sendProgressBar" progress="0" maxWidth="Infinity" prefHeight="6" styleClass="progress-bar-send" />
                    </StackPane>
                    <HBox spacing="8">
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="SENT" styleClass="stat-label" />
                            <Label fx:id="sendStatSent" text="0%" styleClass="stat-value" />
                        </VBox>
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="SPEED" styleClass="stat-label" />
                            <Label fx:id="sendStatSpeed" text="0 MB/s" styleClass="stat-value" />
                        </VBox>
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="ETA" styleClass="stat-label" />
                            <Label fx:id="sendStatEta" text="0s" styleClass="stat-value" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- SCREEN 3: RECEIVE SCREEN -->
            <VBox fx:id="receiveScreen" spacing="16" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Receive File" styleClass="screen-title" />
                </HBox>
                
                <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
                    <VBox styleClass="card" spacing="20" alignment="CENTER" prefWidth="340" maxWidth="340">
                        <padding>
                            <Insets top="32" right="32" bottom="32" left="32" />
                        </padding>
                        <Label text="↓" styleClass="drop-zone-icon" />
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="Waiting for sender" styleClass="screen-title" />
                            <Label text="Enter the invite code you received from the sender." styleClass="status-text" alignment="CENTER" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
                            <Label text="INVITE CODE" styleClass="section-label" />
                            <HBox fx:id="codeInputContainer" styleClass="code-container" alignment="CENTER_LEFT" spacing="8" maxWidth="Infinity">
                                <padding>
                                    <Insets top="10" right="14" bottom="10" left="14" />
                                </padding>
                                <TextField fx:id="inviteCodeInput" promptText="Paste invite code here..." styleClass="code-field" HBox.hgrow="ALWAYS" />
                                <Button fx:id="pasteCodeBtn" text="⎙" styleClass="btn-icon" onAction="#onPasteCode" />
                            </HBox>
                        </VBox>
                        <Button fx:id="receiveBtn" text="↓ Receive File" styleClass="btn, btn-success" maxWidth="Infinity" prefHeight="44" onAction="#onReceive" />
                    </VBox>
                </VBox>
                
                <!-- Progress Section (visible during transfer) -->
                <VBox fx:id="receiveProgressSection" spacing="12" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="receiveFileName" text="" styleClass="transfer-filename" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="receiveFileSize" text="" styleClass="transfer-filesize" />
                    </HBox>
                    <StackPane styleClass="progress-track" prefHeight="6">
                        <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity" prefHeight="6" styleClass="progress-bar-receive" />
                    </StackPane>
                    <HBox spacing="8">
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="RECEIVED" styleClass="stat-label" />
                            <Label fx:id="receivePercent" text="0%" styleClass="stat-value" />
                        </VBox>
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="SPEED" styleClass="stat-label" />
                            <Label fx:id="receiveSpeed" text="0 MB/s" styleClass="stat-value" />
                        </VBox>
                        <VBox styleClass="stat-box" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="ETA" styleClass="stat-label" />
                            <Label fx:id="receiveEta" text="0s" styleClass="stat-value" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- SCREEN 4: DEVICES SCREEN -->
            <VBox fx:id="devicesScreen" spacing="16" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Devices" styleClass="screen-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="↻" styleClass="btn-icon" onAction="#onRefreshDevices" />
                </HBox>
                
                <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
                    <VBox styleClass="card" spacing="20" alignment="CENTER" prefWidth="340" maxWidth="340">
                        <padding>
                            <Insets top="32" right="32" bottom="32" left="32" />
                        </padding>
                        <Label text="◉" styleClass="drop-zone-icon" />
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="No devices found" styleClass="screen-title" />
                            <Label text="Device discovery is not yet implemented. Share your invite code manually to connect." styleClass="status-text" alignment="CENTER" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        <Button text="Copy My Code" styleClass="btn, btn-secondary" maxWidth="Infinity" onAction="#onCopyMyCode" />
                    </VBox>
                </VBox>
                
                <!-- Manual Device Connection -->
                <VBox spacing="6">
                    <Label text="MANUAL CONNECTION" styleClass="section-label" />
                    <HBox styleClass="card" spacing="8" alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="12" right="16" bottom="12" left="16" />
                        </padding>
                        <TextField fx:id="manualIpInput" promptText="Enter IP Address..." styleClass="code-field" HBox.hgrow="ALWAYS" />
                        <Button text="Connect" styleClass="btn, btn-primary" onAction="#onManualConnect" />
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- SCREEN 5: SETTINGS SCREEN -->
            <ScrollPane fx:id="settingsScreen" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" visible="false" managed="false">
                <VBox spacing="20" maxWidth="480">
                    <Label text="Settings" styleClass="screen-title" />
                    
                    <!-- Group 1: Transfer -->
                    <VBox styleClass="settings-group" spacing="8">
                        <Label text="TRANSFER" styleClass="section-label" />
                        <VBox styleClass="card" spacing="0">
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Default save location" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="~/Downloads" styleClass="settings-row-value" />
                                <Button text="Change" styleClass="btn, btn-secondary" onAction="#onChangeDownloadsFolder" />
                            </HBox>
                            <Separator styleClass="settings-divider" />
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Confirm before receiving" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ToggleButton fx:id="confirmReceiveToggle" text="ON" styleClass="btn" selected="true" />
                            </HBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Group 2: Network -->
                    <VBox styleClass="settings-group" spacing="8">
                        <Label text="NETWORK" styleClass="section-label" />
                        <VBox styleClass="card" spacing="0">
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Listening port" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="4220" styleClass="settings-row-value" fx:id="settingsPortLabel" />
                                <Button text="Edit" styleClass="btn, btn-secondary" />
                            </HBox>
                            <Separator styleClass="settings-divider" />
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Your device name" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="LocalHost" styleClass="settings-row-value" fx:id="settingsDeviceNameLabel" />
                                <Button text="Edit" styleClass="btn, btn-secondary" />
                            </HBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Group 3: Appearance -->
                    <VBox styleClass="settings-group" spacing="8">
                        <Label text="APPEARANCE" styleClass="section-label" />
                        <VBox styleClass="card" spacing="0">
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Theme" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="4">
                                    <Button text="Dark" styleClass="btn, btn-primary" />
                                    <Button text="Light" styleClass="btn, btn-secondary" disable="true" />
                                </HBox>
                            </HBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Group 4: About -->
                    <VBox styleClass="settings-group" spacing="8">
                        <Label text="ABOUT" styleClass="section-label" />
                        <VBox styleClass="card" spacing="0">
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Version" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="1.0.0" styleClass="settings-row-value" />
                            </HBox>
                            <Separator styleClass="settings-divider" />
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="Developer" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text=" Code-assembler" styleClass="settings-row-value" />
                            </HBox>
                            <Separator styleClass="settings-divider" />
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="GitHub" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="/souravvoid/filedrop" styleClass="settings-row-value" />
                            </HBox>
                            <Separator styleClass="settings-divider" />
                            <HBox styleClass="settings-row" spacing="12">
                                <padding><Insets left="16" right="16" /></padding>
                                <Label text="License" styleClass="settings-row-label" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="MIT" styleClass="settings-row-value" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets left="16" right="16" />
            </padding>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="statusDot" text="●" styleClass="status-dot, status-dot-idle" />
                <Label fx:id="statusLabel" text="Ready to transfer" styleClass="status-text" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="cancelBtn" text="✕ Cancel" styleClass="btn, btn-danger-outline" visible="false" managed="false" onAction="#onCancel" />
        </HBox>
    </bottom>

</BorderPane>